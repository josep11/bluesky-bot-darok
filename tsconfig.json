{
  "compilerOptions": {
    "module": "es2022",
    "moduleResolution": "node",
    "target": "ESNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "lib": ["ESNext", "DOM"],
//    "moduleDetection": "force",
//    "jsx": "react-jsx",
    "allowJs": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "noEmit": false, // Certifique-se de que isso está definido como false ou removido

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  },
  "include": [
    "./src/**/*"
  ],
  "exclude": [
    "node_modules",
    "tests",
    "tsconfig.json",
    "tsconfig.*.json",
    "playground.js"
  ]
}
